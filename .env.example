# ============================================================
# CortexHire — Environment Configuration Template
# Copy this to .env and fill in your API keys
# ============================================================

# --- LLM Providers ---
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

LLM_PROVIDER=groq
LLM_FALLBACK=openai
OFFLINE_MODE=false

# --- Models ---
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# --- Database (SQLite — no Docker needed) ---
DATABASE_URL=sqlite+aiosqlite:///./cortexhire.db
USE_SQLITE=true

# --- Qdrant (in-memory — no Docker needed) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_CANDIDATES=candidate_capabilities
QDRANT_COLLECTION_ROLES=role_genomes
QDRANT_IN_MEMORY=true

# --- Neo4j (disabled by default) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexhire_secret
NEO4J_ENABLED=false

# --- App Settings ---
APP_ENV=production
APP_PORT=8000
# Add your deployed frontend URL to allow CORS from it
CORS_ORIGINS=http://localhost:3000,https://cortexhire.vercel.app
SECRET_KEY=change-this-to-a-secure-random-string

# --- Frontend ---
# Local dev: http://localhost:8000
# Production backend (Render): https://cortexhire.onrender.com
NEXT_PUBLIC_API_URL=https://cortexhire.onrender.com
